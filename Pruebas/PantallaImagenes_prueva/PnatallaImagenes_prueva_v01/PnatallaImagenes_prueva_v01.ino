void setup() {
  u8g2.begin();
  u8g2.setContrast(255); // Opcional: maximiza contraste
}

void loop() {
  u8g2.clearBuffer();

  // Centrar la imagen
  int x = (128 - 45) / 2;
  int y = (64 - 45) / 2;

  // Mostrar la imagen
  u8g2.drawBitmap(x, y, 45, 45, myBitmap);

  u8g2.sendBuffer();
  delay(1000);
}